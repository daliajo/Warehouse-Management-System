@model WarehouseManagementSystem.Models.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<h1>Supplier Details</h1>

<hr />

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">
                Name
            </dt>

            <dd class="col-sm-9">
                @Model.Name
            </dd>

            <dt class="col-sm-3">
                Phone
            </dt>

            <dd class="col-sm-9">
                @Model.Phone
            </dd>

            <dt class="col-sm-3">
                Email
            </dt>

            <dd class="col-sm-9">
                @Model.Email
            </dd>

            <dt class="col-sm-3">
                Address
            </dt>

            <dd class="col-sm-9">
                @Model.Address
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit"
       asp-route-id="@Model.Id"
       class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to List
    </a>
</div>