@model WarehouseManagementSystem.Models.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<h1>Delete Supplier</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this supplier?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">
                Name
            </dt>

            <dd class="col-sm-9">
                @Model.Name
            </dd>

            <dt class="col-sm-3">
                Phone
            </dt>

            <dd class="col-sm-9">
                @Model.Phone
            </dd>

            <dt class="col-sm-3">
                Email
            </dt>

            <dd class="col-sm-9">
                @Model.Email
            </dd>

            <dt class="col-sm-3">
                Address
            </dt>

            <dd class="col-sm-9">
                @Model.Address
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>