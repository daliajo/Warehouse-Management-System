@model IEnumerable<WarehouseManagementSystem.Models.Supplier>

@{
    ViewData["Title"] = "Suppliers";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Suppliers</h1>
        <p class="text-muted">Manage warehouse suppliers.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Add Supplier
    </a>
</div>

@if (!Model.Any()) //checks whether the collection contains at least one item
{
    <div class="alert alert-info">
        No suppliers have been added yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Address</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var supplier in Model)
                {
                    <tr>
                        <td>@supplier.Name</td>
                        <td>@supplier.Phone</td>
                        <td>@supplier.Email</td>
                        <td>@supplier.Address</td>

                        <td class="text-end">
                        <div class="action-buttons">
                            <a asp-action="Details"
                            asp-route-id="@supplier.Id"
                            class="btn btn-sm btn-details">
                                Details
                            </a>

                            <a asp-action="Edit"
                            asp-route-id="@supplier.Id"
                            class="btn btn-sm btn-edit">
                                Edit
                            </a>

                            <a asp-action="Delete"
                            asp-route-id="@supplier.Id"
                            class="btn btn-sm btn-delete">
                                Delete
                            </a>
                        </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}