@model WarehouseManagementSystem.ViewModels.ProductFormViewModel
@{
    ViewData["Title"] = "Add Product";
}

<h1>Add Product</h1>

<p class="text-muted">
    Enter the product information.
</p>

<hr />

<div class="row">
    <div class="col-md-6">
<form asp-action="Create" method="post" enctype="multipart/form-data"> 
@* multipart/form-data is required because the form contains a file. *@
                  <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="3">
                </textarea>

                <span asp-validation-for="Description"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
            <label asp-for="Price" class="form-label"></label>

            <input asp-for="Price"
                type="text"
                inputmode="decimal"
                class="form-control"/>

            <span asp-validation-for="Price"
                class="text-danger">
            </span>
           </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label"></label>

                <input asp-for="Quantity"
                       class="form-control"
                       type="number" />

                <span asp-validation-for="Quantity"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="SupplierId"
                       class="form-label">
                    Supplier
                </label>

                <select asp-for="SupplierId"
                        asp-items="ViewBag.SupplierId"
                        class="form-select">
                    <option value="">-- Select Supplier --</option>
                </select>

                <span asp-validation-for="SupplierId"
                      class="text-danger">
                </span>
            </div>
<div class="mb-3">
    <label asp-for="ImageFile"
           class="form-label">
    </label>

    <input asp-for="ImageFile"
           type="file"
           accept=".jpg,.jpeg,.png"
           class="form-control" />

    <div class="form-text">
        JPG or PNG only. Maximum size: 2 MB.
    </div>

    <span asp-validation-for="ImageFile"
          class="text-danger">
    </span>
</div>
            <button type="submit" class="btn btn-primary">
                Save
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}