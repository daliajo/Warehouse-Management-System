<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Warehouse Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark warehouse-navbar">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">

                    <span class="brand-icon">W</span>
                    <span>Warehouse Management</span>
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="mainNavbar">

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

                        @if (Context.Session.GetString("Username") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Suppliers"
                                   asp-action="Index">
                                    Suppliers
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Products"
                                   asp-action="Index">
                                    Products
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="StockTransactions"
                                   asp-action="Index">
                                    Transactions
                                </a>
                            </li>

                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-stock-in"
                                   asp-controller="StockTransactions"
                                   asp-action="StockIn">
                                    Stock In
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-stock-out"
                                   asp-controller="StockTransactions"
                                   asp-action="StockOut">
                                    Stock Out
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-outline-light"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <span>Warehouse Management System</span>
            <span>ASP.NET Core MVC</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* Loads jQuery, which your client-side validation libraries *@

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
    @* This allows an individual View to add scripts near the bottom of the page *@
</body>
</html>